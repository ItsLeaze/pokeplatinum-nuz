  "messages": [
    {
      "id": "SnowpointCityWestHouse_Text_SuchVivacityAndCharm",
      "en_US": [
        "I love how my girl has so much\n",
        "vivacity and charm."
      ]
    },
    {
      "id": "SnowpointCityWestHouse_Text_MyGirlsHappy",
      "en_US": [
        "Thanks to you, my girl’s been in\n",
        "a really happy mood."
      ]
    },
    {
      "id": "SnowpointCityWestHouse_Text_AskTradeMedichamForHaunter",
      "en_US": [
        "By any chance, do you have a Pokémon\n",
        "you can trade me?\r",
        "If you do, would you like to trade\n",
        "you this ugly GRIMER?"
      ]
    },
    {
      "id": "SnowpointCityWestHouse_Text_IMadeItPreventEvolving",
      "en_US": [
        "Haha! Did my GRIMER turn into\n",
        "something else? I hope it looks\r",
        "less ugly when it evolves..."
      ]
    },
    {
      "id": "SnowpointCityWestHouse_Text_IAskedForMedicham",
      "en_US": "What I asked for was a Pokémon...?"
    },
    {
      "id": "SnowpointCityWestHouse_Text_OKIfYouDontWant",
      "en_US": [
        "It’s OK if you don’t want to.\r",
        "But if you change your mind, let’s\n",
        "trade Pokémon."
      ]
    },
    {
      "id": "SnowpointCityWestHouse_Text_WeGotToBeFriends",
      "en_US": [
        "Thanks to Pokémon, we got to be\n",
        "friends, didn’t we?"
      ]
    }
  ]
}
