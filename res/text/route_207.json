  "key": 40580,
  "messages": [
    {
      "id": "Route207_Text_DawnPlayerChooseWhichHandYouWant",
      "en_US": [
        "Dawn: Hi, {STRVAR_1 3, 0, 0}!\n",
        "How’s your Pokédex coming along?\r",
        "Me? I’m somewhere between fantastic\n",
        "and, uh, hopeless...\r",
        "But this isn’t about me!\n",
        "I’ve got something nice for you.\r",
        "{STRVAR_1 3, 0, 0}, choose which hand\n",
        "you want."
      ]
    },
    {
      "id": "Route207_Text_DawnISeeYouWantTheVsSeeker",
      "en_US": [
        "Dawn: I see...\n",
        "You want the Vs. Seeker.\r",
        "I’m impressed, {STRVAR_1 3, 0, 0}.\n",
        "You know what’s important.\r"
      ]
    },
    {
      "id": "Route207_Text_DawnYouCanHaveThisTooThen",
      "en_US": [
        "Dawn: Using that Vs. Seeker, you can\n",
        "find Trainers who want a rematch\f",
        "with you.\r",
        "I see you also have a Pokétch.\n",
        "You can have this too, then.\r"
      ]
    },
    {
      "id": "Route207_Text_HowMuchHaveYouImproved",
      "en_US": [
        "Dawn: Besides, how much have your\n",
        "battle skills improved?\r",
        "Let’s put them to the test!\r"
      ]
    },
    {
      "id": "Route207_Text_LucasPlayerIllShareWithYouChooseAHand",
      "en_US": [
        "Lucas: Hey, {STRVAR_1 3, 0, 0}!\n",
        "How’s your Pokédex coming along?\r",
        "Me? I’m always doing great!\n",
        "...I wish...\r",
        "But that’s not important.\r",
        "Lately, I’ve been experimenting with\n",
        "a couple of neat tools.\r",
        "{STRVAR_1 3, 0, 0}, I’ll share with you.\n",
        "Choose a hand!"
      ]
    },
    {
      "id": "Route207_Text_LucasOhYeahYouWantTheVsSeeker",
      "en_US": [
        "Lucas: Oh yeah.\n",
        "You want the Vs. Seeker.\r",
        "Yup, {STRVAR_1 3, 0, 0}, you know what’s\n",
        "important.\r"
      ]
    },
    {
      "id": "Route207_Text_LucasYouCanHaveThisTooThen",
      "en_US": [
        "Lucas: Using that Vs. Seeker, you can\n",
        "find Trainers who want to battle with\f",
        "you again.\r",
        "{STRVAR_1 3, 0, 0}, what about a Pokétch?\n",
        "Do you have one?\r",
        "Yup, you do.\n",
        "You can have this too, then.\r",
        "You deserve it for all of your\n",
        "effort, {STRVAR_1 3, 0, 0}.\r"
      ]
    },
    {
      "id": "Route207_Text_LucasHowMuchHaveYouImproved",
      "en_US": [
        "Lucas: Besides, how much have your\n",
        "battle skills improved?\r",
        "Let’s put them to the test!\r"
      ]
    },
    {
      "id": "Route207_Text_Dummy8",
      "garbage": 59
    },
    {
      "id": "Route207_Text_ThatSlopesTooSlippery",
      "en_US": [
        "That slope’s too slippery.\n",
        "You’ll need a Bike to get up.\r",
        "You don’t have a Bicycle?\n",
        "There’s a Cycle Shop in Eterna City."
      ]
    },
    {
      "id": "Route207_Text_ChangeToThe4thGearAndTakeARun",
      "en_US": [
        "Change to the 4th gear and take a run.\n",
        "That’ll shoot you right up that slope."
      ]
    },
    {
      "id": "Route207_Text_Rt207MtCoronet",
      "en_US": [
        "Rt. 207\n",
        "Mt. Coronet"
      ]
    },
    {
      "id": "Route207_Text_Rt207OreburghCity",
      "en_US": [
        "Rt. 207\n",
        "Oreburgh City"
      ]
    },
    {
      "id": "Route207_Text_TrainerTipsPokemonMayBecomeImmobilizedIfTheyAreAsleepOrParalyzed",
      "en_US": [
        "Trainer Tips\r",
        "Pokémon may become immobilized if\n",
        "they are asleep or paralyzed.\r",
        "If it happens to your Pokémon,\n",
        "it could be disastrous.\r",
        "If your opponent’s Pokémon can’t\n",
        "move, it’s a big opportunity!"
      ]
    },
    {
      "id": "Route207_Text_YouImproved",
      "en_US": [
        "Your improvement is astounding!\r"
      ]
    }
  ]
}
