    {
      "id": "EternaCityCondominiums2F_Text_IveHadThisTMRecycleForSuchALongTimeNow",
      "en_US": [
        "There is so much potential in\n",
        "recycling used things!\r",
        "Think about it.\r"
      ]
    },
    {
      "id": "EternaCityCondominiums2F_Text_FolksLikeMeHaveALongHistoryWeCanLookBackOn",
      "en_US": [
        "Folks like me have a long history\n",
        "we can look back on.\r",
        "Young people like you have only the\n",
        "future to look forward to."
      ]
    },
    {
      "id": "EternaCityCondominiums2F_Text_GardeniaOurGymLeaderGoesOutToEternaForestEverySoOften",
      "en_US": [
        "Gardenia, our Gym Leader, goes out\n",
        "to Eterna Forest every so often.\r",
        "I always wonder what she does there."
      ]
    },
    {
      "id": "EternaCityCondominiums2F_Text_TheMoveRecycleIsToBeUsedDuringBattle",
      "en_US": [
        "The move Recycle is to be used during\n",
        "battle.\r",
        "When you use Recycle, a Pokémon can\n",
        "use its item once again."
      ]
    }
  ]
}
