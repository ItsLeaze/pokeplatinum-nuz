{
  "key": 37906,
  "messages": [
    {
      "id": "EternaCityCondominiums1F_Text_WantMeToRateTheNicknamesOfYourPokemon",
      "en_US": [
        "Hello, hello!\n",
        "I am the official Name Rater!\r",
        "Want me to rate the nicknames of\n",
        "your Pokémon?"
      ]
    },
    {
      "id": "EternaCityCondominiums1F_Text_WhichPokemonsNicknameShouldICritique",
      "en_US": [
        "Which Pokémon’s nickname should\n",
        "I critique?"
      ]
    },
    {
      "id": "EternaCityCondominiums1F_Text_WouldYouLikeToGiveItAnEvenBetterName",
      "en_US": [
        "{STRVAR_1 1, 0, 0}, is it?\n",
        "That’s a decent nickname!\r",
        "But would you like to give it\n",
        "an even better name?\r",
        "How about it?"
      ]
    },
    {
      "id": "EternaCityCondominiums1F_Text_AhGoodThenWhatShallTheNewNicknameBe",
      "en_US": [
        "Ah, good. Then, what shall the new\n",
        "nickname be?"
      ]
    },
    {
      "id": "EternaCityCondominiums1F_Text_ThisPokemonShallBeKnownAsNicknameItIsABetterNameThanBefore",
      "en_US": [
        "Done! From now on, this Pokémon\n",
        "shall be known as {STRVAR_1 1, 0, 0}!\r",
        "It is a better name than before!\n",
        "How fortunate for you!"
      ]
    },
    {
      "id": "EternaCityCondominiums1F_Text_ISeePleaseComeVisitAgain",
      "en_US": [
        "I see.\n",
        "Please come visit again."
      ]
    },
    {
      "id": "EternaCityCondominiums1F_Text_ThisPokemonShallBeKnownAsNicknameItLooksNoDifferentFromBefore",
      "en_US": [
        "Done! From now on, this Pokémon\n",
        "shall be known as {STRVAR_1 1, 0, 0}!\r",
        "It looks no different from before,\n",
        "and yet, this is vastly superior!\r",
        "How fortunate for you!"
      ]
    },
    {
      "id": "EternaCityCondominiums1F_Text_NicknameIsItThatIsATrulyImpeccableName",
      "en_US": [
        "{STRVAR_1 1, 0, 0}, is it?\n",
        "That is a truly impeccable name!\r",
        "Take good care of {STRVAR_1 1, 0, 0}!"
      ]
    },
    {
      "id": "EternaCityCondominiums1F_Text_AnEggCanGoByNoOtherName",
      "en_US": [
        "Now, now. That is merely an Egg!\n",
        "An Egg can go by no other name!\n"
      ]
    },
    {
      "id": "EternaCityCondominiums1F_Text_WannaTradeAPokemon",
      "en_US": [
        "Excuse me, but do you want a\n",
        "SPEAROW by chance?\r",
        "I can trade it to you if you\n",
        "give me a cool Pokémon in response."
      ]
    },
    {
      "id": "EternaCityCondominiums1F_Text_YesSoAwesomeABuizel",
      "en_US": [
        "Yes! So awesome!\n",
        "I so promise I’ll be good to it!"
      ]
    },
    {
      "id": "EternaCityCondominiums1F_Text_WhatITotallyWantIsABuizel",
      "en_US": "What I totally want is a BUIZEL..."
    },
    {
      "id": "EternaCityCondominiums1F_Text_OhOKTotallyGotIt",
      "en_US": [
        "Oh, OK. Totally got it.\n",
        "It’s all right if you don’t want to.\r",
        "But if you change your mind,\n",
        "let’s totally trade some Pokémon."
      ]
    },
    {
      "id": "EternaCityCondominiums1F_Text_DidThatChatotITradedYouTotallyLearnThatChatterMove",
      "en_US": [
        "Did that SPEAROW I traded you totally\n",
        "learn some cool moves?"
      ]
    },
    {
      "id": "EternaCityCondominiums1F_Text_HiImTheBuildingSuperintented",
      "en_US": [
        "Hi! I’m the building superintendent.\n",
        "I maintain a vigilant 24-hour watch!"
      ]
    },
    {
      "id": "EternaCityCondominiums1F_Text_ImBuildingSuperintendentMantain24HourWatchZZZ",
      "en_US": [
        "I’m...building...superintendent...\n",
        "...maintain...24-hour watch... Zzz..."
      ]
    }
  ]
}
